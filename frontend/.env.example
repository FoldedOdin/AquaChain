# AWS Configuration
REACT_APP_AWS_REGION=us-east-1
REACT_APP_USER_POOL_ID=us-east-1_example
REACT_APP_USER_POOL_CLIENT_ID=example_client_id
REACT_APP_IDENTITY_POOL_ID=us-east-1:example-identity-pool-id

# API Configuration
REACT_APP_API_ENDPOINT=https://api.aquachain.example.com

# WebSocket Configuration
REACT_APP_WEBSOCKET_ENDPOINT=wss://websocket.aquachain.example.com

# Analytics Configuration
REACT_APP_PINPOINT_APPLICATION_ID=your-pinpoint-app-id
REACT_APP_AWS_ACCESS_KEY_ID=your-access-key-id
REACT_APP_AWS_SECRET_ACCESS_KEY=your-secret-access-key
REACT_APP_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Feature Flags
REACT_APP_ENABLE_MOCK_DATA=true
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_AB_TESTING=true

# Security Configuration
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id
REACT_APP_RECAPTCHA_SITE_KEY=your_recaptcha_site_key