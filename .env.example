# Google OAuth Configuration
# Get these from Google Cloud Console: https://console.cloud.google.com/

# Your Google OAuth Client ID
REACT_APP_GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com

# Your Google OAuth Client Secret (keep this secret!)
REACT_APP_GOOGLE_CLIENT_SECRET=your-client-secret-here

# OAuth Redirect URI (must match Google Console configuration)
# Development
REACT_APP_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Production (uncomment and update for production)
# REACT_APP_OAUTH_REDIRECT_URI=https://yourdomain.com/auth/google/callback

# Base URL
REACT_APP_BASE_URL=http://localhost:3000

# Production (uncomment and update for production)
# REACT_APP_BASE_URL=https://yourdomain.com

# Backend API URL
REACT_APP_API_URL=http://localhost:3002

# Production (uncomment and update for production)
# REACT_APP_API_URL=https://api.yourdomain.com

# Contact Form API URL (separate API Gateway)
REACT_APP_CONTACT_API_URL=https://946twwm7kf.execute-api.ap-south-1.amazonaws.com/prod

# Razorpay Configuration
# Get these from Razorpay Dashboard: https://dashboard.razorpay.com/app/keys

# Razorpay Key ID (public key - safe to expose in frontend)
REACT_APP_RAZORPAY_KEY_ID=rzp_test_your_key_id_here

# For production, use live keys (starts with rzp_live_)
# REACT_APP_RAZORPAY_KEY_ID=rzp_live_your_key_id_here
