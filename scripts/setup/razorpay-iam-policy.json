{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "RazorpaySecretsManagerAccess",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:CreateSecret",
        "secretsmanager:GetSecretValue",
        "secretsmanager:PutSecretValue",
        "secretsmanager:UpdateSecret",
        "secretsmanager:DescribeSecret",
        "secretsmanager:ListSecrets"
      ],
      "Resource": [
        "arn:aws:secretsmanager:us-east-1:758346259059:secret:aquachain-secret-razorpay-credentials-*"
      ]
    }
  ]
}
