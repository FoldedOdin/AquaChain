{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CognitoReadAccess",
      "Effect": "Allow",
      "Action": [
        "cognito-idp:ListUsers",
        "cognito-idp:DescribeUserPool",
        "cognito-idp:ListUserPools"
      ],
      "Resource": [
        "arn:aws:cognito-idp:ap-south-1:*:userpool/ap-south-1_QUDl7hG8u"
      ]
    },
    {
      "Sid": "CloudWatchMetricsAccess",
      "Effect": "Allow",
      "Action": [
        "cloudwatch:GetMetricStatistics",
        "cloudwatch:ListMetrics"
      ],
      "Resource": "*"
    },
    {
      "Sid": "LambdaReadAccess",
      "Effect": "Allow",
      "Action": [
        "lambda:GetFunction",
        "lambda:ListFunctions"
      ],
      "Resource": "*"
    },
    {
      "Sid": "APIGatewayReadAccess",
      "Effect": "Allow",
      "Action": [
        "apigateway:GET"
      ],
      "Resource": [
        "arn:aws:apigateway:ap-south-1::/restapis/vtqjfznspc/*"
      ]
    }
  ]
}
