              "raw": "{\n  \"supplier_id\": \"{{supplier_id}}\",\n  \"items\": [\n    {\n      \"item_id\": \"ESP32-SENSOR-001\",\n      \"quantity\": 100,\n      \"unit_price\": 45.99,\n      \"description\": \"ESP32 Water Quality Sensor\"\n    },\n    {\n      \"item_id\": \"CABLE-USB-C-001\",\n      \"quantity\": 100,\n      \"unit_price\": 12.99,\n      \"description\": \"USB-C Cable for Sensor\"\n    }\n  ],\n  \"total_amount\": 5898.00,\n  \"expected_delivery\": \"2026-02-15\",\n  \"delivery_address\": \"AquaChain Warehouse, 456 Industrial Blvd, Tech City, CA\",\n  \"special_instructions\": \"Quality inspection required upon receipt\",\n  \"priority\": \"normal\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/purchase-orders",
