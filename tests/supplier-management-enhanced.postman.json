{
  "info": {
    "name": "AquaChain Supplier Management - Enhanced API",
    "description": "Comprehensive API collection for testing the enhanced supplier management service with dashboard overhaul features including audit logging, performance scoring, financial risk assessment, and contract management",
    "version": "2.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://api.aquachain.com/api",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "supplier_id",
      "value": "SUPPLIER-001",
      "type": "string"
    },
    {
      "key": "contract_id",
      "value": "CONTRACT-001",
      "type": "string"
    },
    {
      "key": "po_id",
      "value": "PO-001",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Supplier Profile Management",
      "item": [
        {
          "name": "Get Suppliers List",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/suppliers?status=active&category=electronics&limit=50",
              "host": ["{{base_url}}"],
              "path": ["suppliers"],
              "query": [
                {
                  "key": "status",
                  "value": "active",
                  "description": "Filter by supplier status"
                },
                {
                  "key": "category",
                  "value": "electronics",
                  "description": "Filter by supplier category"
                },
                {
                  "key": "limit",
                  "value": "50",
                  "description": "Maximum number of results"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has suppliers array', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('suppliers');",
                  "    pm.expect(jsonData.suppliers).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Response time is acceptable', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create New Supplier",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"supplier_name\": \"TechSensors Inc\",\n  \"contact_email\": \"orders@techsensors.com\",\n  \"contact_phone\": \"+1-555-0123\",\n  \"address\": \"123 Tech Street, Silicon Valley, CA\",\n  \"category\": \"electronics\",\n  \"payment_terms\": \"NET30\",\n  \"api_endpoint\": \"https://api.techsensors.com/orders\",\n  \"notes\": \"Primary supplier for ESP32 sensors\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/suppliers",
              "host": ["{{base_url}}"],
              "path": ["suppliers"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response contains supplier_id', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('supplier_id');",
                  "    pm.environment.set('created_supplier_id', jsonData.supplier_id);",
                  "});",
                  "",
                  "pm.test('Audit trail created', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('audit_id');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update Supplier Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contact_email\": \"neworders@techsensors.com\",\n  \"contact_phone\": \"+1-555-0124\",\n  \"payment_terms\": \"NET15\",\n  \"notes\": \"Updated contact information per supplier request - January 2026\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/suppliers/{{supplier_id}}",
              "host": ["{{base_url}}"],
              "path": ["suppliers", "{{supplier_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Changes applied correctly', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.supplier.contact_email).to.eql('neworders@techsensors.com');",
                  "    pm.expect(jsonData.supplier.payment_terms).to.eql('NET15');",
                  "});",
                  "",
                  "pm.test('Audit trail updated', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('audit_id');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Performance Metrics",
      "item": [
        {
          "name": "Get Supplier Performance",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/suppliers/{{supplier_id}}/performance?period=12months",
              "host": ["{{base_url}}"],
              "path": ["suppliers", "{{supplier_id}}", "performance"],
              "query": [
                {
                  "key": "period",
                  "value": "12months",
                  "description": "Performance analysis period"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Performance metrics present', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.performance_metrics).to.have.property('on_time_delivery_rate');",
                  "    pm.expect(jsonData.performance_metrics).to.have.property('quality_score');",
                  "    pm.expect(jsonData.performance_metrics).to.have.property('overall_score');",
                  "});",
                  "",
                  "pm.test('Recommendations provided', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('recommendations');",
                  "    pm.expect(jsonData.recommendations).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
