  "item": [
    {
      "name": "Warehouse Overview",
      "item": [
        {
          "name": "Get Warehouse Overview",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has overview data', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('overview');",
                  "    pm.expect(jsonData.overview).to.have.property('total_locations');",
                  "    pm.expect(jsonData.overview).to.have.property('occupancy_rate');",
                  "    pm.expect(jsonData.overview).to.have.property('performance_metrics');",
                  "});",
                  "",
                  "pm.test('Performance metrics structure is valid', function () {",
                  "    const jsonData = pm.response.json();",
                  "    const metrics = jsonData.overview.performance_metrics;",
                  "    pm.expect(metrics).to.have.property('throughput');",
                  "    pm.expect(metrics).to.have.property('efficiency');",
                  "    pm.expect(metrics).to.have.property('quality');",
                  "});",
                  "",
                  "pm.test('Response time is acceptable', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Correlation-ID",
                "value": "{{correlation_id}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/warehouse/overview",
              "host": ["{{base_url}}"],
              "path": ["api", "warehouse", "overview"]
            }
          }
        }
      ]
    },
