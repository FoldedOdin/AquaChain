              "raw": "{\n  \"item_id\": \"ESP32-SENSOR-001\",\n  \"forecast_period_days\": 90,\n  \"model_version\": \"v1.2\",\n  \"include_seasonality\": true,\n  \"include_promotions\": false\n}"
