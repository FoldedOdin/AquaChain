{
  "info": {
    "name": "AquaChain Inventory Management API",
    "description": "API collection for testing AquaChain inventory management system endpoints",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://api.aquachain.com/v1",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Inventory Items",
      "item": [
        {
          "name": "Create Inventory Item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"item_id\": \"ESP32-SENSOR-001\",\n  \"location_id\": \"WH001-A1-S1\",\n  \"name\": \"ESP32 Water Quality Sensor\",\n  \"description\": \"IoT sensor for monitoring water quality parameters\",\n  \"category\": \"sensors\",\n  \"supplier_id\": \"SUPPLIER-001\",\n  \"current_stock\": 100,\n  \"reorder_point\": 20,\n  \"safety_stock\": 10,\n  \"max_stock\": 500,\n  \"unit_cost\": 45.99,\n  \"lead_time_days\": 14,\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/inventory/items",
              "host": ["{{base_url}}"],
              "path": ["inventory", "items"]
            }
          },
          "response": []
        },
        {
          "name": "Get Inventory Item",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/inventory/items/ESP32-SENSOR-001/WH001-A1-S1",
              "host": ["{{base_url}}"],
              "path": ["inventory", "items", "ESP32-SENSOR-001", "WH001-A1-S1"]
            }
          },
          "response": []
        },
        {
          "name": "Update Stock Level",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_stock\": 85,\n  \"transaction_type\": \"consumption\",\n  \"quantity\": 15,\n  \"reason\": \"Device order fulfillment\",\n  \"reference_id\": \"ORDER-12345\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/inventory/items/ESP32-SENSOR-001/WH001-A1-S1/stock",
              "host": ["{{base_url}}"],
              "path": ["inventory", "items", "ESP32-SENSOR-001", "WH001-A1-S1", "stock"]
            }
          },
          "response": []
        },
        {
          "name": "List Items by Category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/inventory/items?category=sensors&limit=50",
              "host": ["{{base_url}}"],
              "path": ["inventory", "items"],
              "query": [
                {
                  "key": "category",
                  "value": "sensors"
                },
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Low Stock Items",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/inventory/items/low-stock",
              "host": ["{{base_url}}"],
              "path": ["inventory", "items", "low-stock"]
            }
          },
          "response": []
        }
      ]
    },
