  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Generate correlation ID for request tracing",
          "const correlationId = 'req_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);",
          "pm.globals.set('correlation_id', correlationId);",
          "",
          "// Set timestamp for requests",
          "pm.globals.set('timestamp', new Date().toISOString());",
          "",
          "// Add correlation ID header",
          "pm.request.headers.add({",
          "    key: 'X-Correlation-ID',",
          "    value: correlationId",
          "});"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Basic response validation",
          "pm.test('Response status is successful', function () {",
          "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 202, 204]);",
          "});",
          "",
          "pm.test('Response time is acceptable (<500ms)', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(500);",
          "});",
          "",
          "pm.test('Response has correct content type', function () {",
          "    if (pm.response.code !== 204) {",
          "        pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
          "    }",
          "});",
          "",
          "// Security headers validation",
          "pm.test('Security headers are present', function () {",
          "    pm.expect(pm.response.headers.get('X-Content-Type-Options')).to.eql('nosniff');",
          "    pm.expect(pm.response.headers.get('X-Frame-Options')).to.eql('DENY');",
          "    pm.expect(pm.response.headers.get('Strict-Transport-Security')).to.include('max-age');",
          "});",
          "",
          "// Correlation ID validation",
          "pm.test('Correlation ID is returned', function () {",
          "    if (pm.response.json() && pm.response.json().correlation_id) {",
          "        pm.expect(pm.response.json().correlation_id).to.be.a('string');",
          "    }",
          "});",
          "",
          "// Store authentication tokens",
          "if (pm.response.code === 200 && pm.response.json().access_token) {",
          "    pm.globals.set('auth_token', pm.response.json().access_token);",
          "    pm.globals.set('refresh_token', pm.response.json().refresh_token);",
          "}",
          "",
          "// Store workflow ID for subsequent requests",
          "if (pm.response.code === 201 && pm.response.json().workflow_id) {",
          "    pm.globals.set('workflow_id', pm.response.json().workflow_id);",
          "}",
          "",
          "// Store user ID for admin operations",
          "if (pm.response.code === 201 && pm.response.json().user_id) {",
          "    pm.globals.set('user_id', pm.response.json().user_id);",
          "}",
          "",
          "// Validate RBAC responses",
          "if (pm.request.url.toString().includes('/rbac/')) {",
          "    pm.test('RBAC response has required fields', function () {",
          "        const response = pm.response.json();",
          "        if (response.permissions) {",
          "            pm.expect(response.permissions).to.be.an('array');",
          "        }",
          "        if (response.roles) {",
          "            pm.expect(response.roles).to.be.an('array');",
          "        }",
          "    });",
          "}",
          "",
          "// Validate audit responses",
          "if (pm.request.url.toString().includes('/audit/')) {",
          "    pm.test('Audit response has integrity fields', function () {",
          "        const response = pm.response.json();",
          "        if (response.audit_entries) {",
          "            pm.expect(response.audit_entries).to.be.an('array');",
          "            if (response.audit_entries.length > 0) {",
          "                pm.expect(response.audit_entries[0]).to.have.property('timestamp');",
          "                pm.expect(response.audit_entries[0]).to.have.property('user_id');",
          "                pm.expect(response.audit_entries[0]).to.have.property('action');",
          "            }",
          "        }",
          "    });",
          "}"
        ]
      }
    }
  ]
