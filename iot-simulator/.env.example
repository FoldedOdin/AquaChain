# AquaChain IoT Simulator Environment Configuration
# Copy this file to .env and update with your AWS settings

# AWS Configuration
AWS_REGION=us-east-1
AWS_IOT_ENDPOINT=your-iot-endpoint.iot.us-east-1.amazonaws.com

# AWS Credentials (optional - can use AWS CLI or IAM roles instead)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Simulation Settings
SIMULATION_MODE=true
LOG_LEVEL=INFO
READING_INTERVAL=30

# Demo Configuration
ENABLE_DEMO_CONTROLLER=true
DEMO_PORT=8080

# Device Configuration Override
# DEVICE_COUNT=3
# FORCE_SCENARIO=normal