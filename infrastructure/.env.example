# AWS Credentials for CDK Deployment
# Copy to .env and fill in your values

# AWS Account Configuration
AWS_ACCOUNT_ID=123456789012
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_SECURITY_TOKEN=your-security-token
AWS_SESSION_TOKEN=your-session-token

# CDK Configuration
CDK_DEFAULT_ACCOUNT=123456789012
CDK_DEFAULT_REGION=us-east-1

# Environment Configuration
ENVIRONMENT=dev
PROJECT_NAME=aquachain

# Domain Configuration
DOMAIN_NAME=dev.aquachain.io
CERTIFICATE_ARN=arn:aws:acm:us-east-1:123456789012:certificate/your-cert-id

# Notification Configuration
ALERT_EMAIL=alerts@yourdomain.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
PAGERDUTY_INTEGRATION_KEY=your-pagerduty-key

# Google OAuth Configuration (for Cognito social login)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Cross-account Replication (for staging/prod environments)
REPLICA_ACCOUNT_ID=987654321098
REPLICA_REGION=us-west-2

# Production Feature Flags
ENABLE_MOCK_DATA=false
ENABLE_DETAILED_MONITORING=false
ENABLE_XRAY_TRACING=true
ENABLE_DELETION_PROTECTION=false

# Resource Configuration
DYNAMODB_BILLING_MODE=PAY_PER_REQUEST
LAMBDA_RESERVED_CONCURRENCY=10
API_THROTTLE_RATE_LIMIT=100
API_THROTTLE_BURST_LIMIT=200
LOG_RETENTION_DAYS=7